    "num = int(input(\"Enter the number: \"))\n",
    "\n",
    "if num % 3 == 0 and num % 5 == 0:\n",
    "    print(f' {num} - Divisible by both 3 and 5 ')\n",
    "else:\n",
    "    print(\"Not Divisible\")"
